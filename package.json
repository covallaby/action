{
  "name": "covallaby-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm lint && pnpm build && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
