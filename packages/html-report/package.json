{
  "name": "@covallaby/html-report",
  "version": "0.1.0",
  "description": "Covallaby's static HTML coverage report — a single self-contained file, no server required.",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./template": "./dist/index.html",
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@covallaby/core": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.6",
    "vite": "^6.1.0",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
